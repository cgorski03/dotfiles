# change window focus within space
alt + shift - k : yabai -m window --focus north
alt + shift - j : yabai -m window --focus south
alt + shift - h : yabai -m window --focus west
alt + shift - l : yabai -m window --focus east

# Swap windows within space
alt - k : yabai -m window --swap north
alt - j : yabai -m window --swap south
alt - h : yabai -m window --swap west
alt - l : yabai -m window --swap east

# change focus between external displays
alt + shift - w : ~/.config/yabai/focus-display north
alt + shift - s : ~/.config/yabai/focus-display south
alt + shift - d : ~/.config/yabai/focus-display east
alt + shift - a : ~/.config/yabai/focus-display west

# move window to display left and right
alt - w : yabai -m window --display north; yabai -m display --focus north
alt - s : yabai -m window --display south; yabai -m display --focus south
alt - d : yabai -m window --display east; yabai -m display --focus east
alt - a : yabai -m window --display west; yabai -m display --focus west

# move between spaces
alt - q : ~/.config/yabai/space-on-display prev --move-window
alt - e : ~/.config/yabai/space-on-display next --move-window
alt + shift - q : ~/.config/yabai/space-on-display prev
alt + shift - e : ~/.config/yabai/space-on-display next

# flip along x-axis
alt + shift - 0x24 : yabai -m space --rotate 180  # 0x24 is return key

# Expand window left
alt + shift - u : yabai -m window --resize left:-50:0

# Expand window right
alt + shift - o : yabai -m window --resize right:50:0

# Delete space
alt + shift - delete : yabai -m space --destroy

alt + shift - z : yabai --restart-service
